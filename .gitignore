# Dependencies (the runtime uses the committed self-contained dist bundle)
node_modules/

# Logs / OS cruft
*.log
npm-debug.log*
.DS_Store

# Local snapshot data (also defaults to ~/.fantasy-wc-mcp outside the repo)
data/
*.local

# Editor
.vscode/
.idea/

# Sport5 copyrighted reference docs — kept locally, never published.
# The game rules are encoded in our own mcp-server/src/rules.ts instead.
fantasywc-sport5-terms-and-conditions.md
fantasywc-sport5-faq.md

# TypeScript / esbuild build cruft (the committed dist/index.js bundle is intentional)
*.tsbuildinfo
mcp-server/dist/*.map

# Generated league-matchups output files
league-matchups-*.txt

# Local credentials — never commit
.env
